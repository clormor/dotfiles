[includeIf "gitdir:**/coder/dotfiles/"]
    path = ~/.gitconfig-work
[includeIf "gitdir:work/"]
    path = ~/.gitconfig-work
[includeIf "gitdir:/Users/"]
    path = ~/.gitconfig-osx
    path = ~/.gitconfig-gpg
[core]
    autocrlf = input
    editor = vim
    excludesfile = ~/.gitignore_global
    hooksPath = ~/.hooks
    ignorecase = true
    longpaths = true
    whitespace = trailing-space,space-before-tab
[apply]
    whitespace = fix
[branch]
    autosetuprebase = always
[color]
    ui = true
[pull]
    rebase = true
[filesystem "Azul Systems, Inc.|1.8.0_221|/dev/disk1s5"]
    timestampResolution = 1001 milliseconds
    minRacyThreshold = 0 nanoseconds
[filesystem "Azul Systems, Inc.|1.8.0_232|/dev/disk1s5"]
    timestampResolution = 1001 milliseconds
    minRacyThreshold = 0 nanoseconds
[advice]
    detachedHead = false
[push]
    default = current
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[init]
    defaultBranch = develop
[user]
	email = 3955231+clormor@users.noreply.github.com
	name = Chris Lormor
[merge]
	tool = vscode
[mergetool "vscode"]
	cmd = code --wait $MERGED
